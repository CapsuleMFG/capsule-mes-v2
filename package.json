{
  "name": "capsule-mes-v2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @capsule/db generate",
    "db:migrate": "pnpm --filter @capsule/db migrate"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
