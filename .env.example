# Copy to .env and fill in. Point at a FRESH Supabase project/branch for v2 —
# do NOT reuse v1's production database.
#
# Use the Supabase SESSION POOLER URI (tenant-qualified user, IPv4), NOT the
# direct db.<ref>.supabase.co host (IPv6-only, fails from many hosts):
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

API_PORT=3001
CORS_ORIGIN=http://localhost:5173

# web (Vite)
VITE_API_URL=http://localhost:3001
